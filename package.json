{
  "name": "theskyisnotreal",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "description": "the sky is not real: a satirical landing page on Cloudflare Workers",
  "scripts": {
    "build": "node build.js",
    "build:worker": "wrangler deploy --dry-run --outdir .wrangler/test-build",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "pretest": "npm run build:worker",
    "test": "node --test 'test/**/*.test.js'",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --grep @smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "miniflare": "^4.20260701.0",
    "wrangler": "^4.24.4"
  },
  "dependencies": {
    "workers-og": "^0.0.27"
  }
}
