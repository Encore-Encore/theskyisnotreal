{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "theskyisnotreal",
  "main": "src/index.js",
  "compatibility_date": "2026-07-06",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    // Run the Worker before serving assets so host-level logic (the www->apex
    // canonical 301) executes even for paths that match a static file.
    "run_worker_first": true
  },
  // Custom domains (cutover complete). Both apex and www are attached to the
  // Worker; the old www CNAME was removed first to avoid a deploy-time conflict.
  "routes": [
    { "pattern": "theskyisnotreal.com", "custom_domain": true },
    { "pattern": "www.theskyisnotreal.com", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  }
}
